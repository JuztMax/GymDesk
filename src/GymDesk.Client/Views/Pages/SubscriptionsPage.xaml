<UserControl x:Class="GymDesk.Client.Views.Pages.SubscriptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="BtnAdd" 
                    Content="➕ Новый абонемент" Width="150" Margin="0,0,10,0" 
                    Click="BtnAdd_Click"/>

            <Button x:Name="BtnEdit" 
                    Content="✏️ Изменить" Width="120" Margin="0,0,10,0" 
                    Click="BtnEdit_Click"/>

            <Button x:Name="BtnDelete" 
                    Content="🗑️ Удалить" Width="100" 
                    Background="#e74c3c" Foreground="White" 
                    Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- Таблица данных -->
        <DataGrid x:Name="SubscriptionsDataGrid"
                  Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>

                <!-- Показываем Фамилию клиента -->
                <DataGridTextColumn Header="Клиент" Binding="{Binding Client.LastName}" Width="*"/>

                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="*"/>

                <!-- 👇 ИЗМЕНЕНО: Формат ДД.ММ.ГГГГ и фиксированная ширина -->
                <DataGridTextColumn Header="Начало" 
                                    Binding="{Binding StartDate, StringFormat='dd.MM.yyyy'}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Конец" 
                                    Binding="{Binding EndDate, StringFormat='dd.MM.yyyy'}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='N2'}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>