<UserControl x:Class="GymDesk.Client.Views.TrainersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="➕ Добавить тренера" Width="140" Margin="0,0,10,0" Click="BtnAdd_Click"/>
            <Button Content="✏️ Редактировать" Width="120" Margin="0,0,10,0" Click="BtnEdit_Click"/>
            <Button Content="🗑️ Удалить" Width="100" Background="#e74c3c" Foreground="White" Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- Таблица тренеров -->
        <!-- 👇 ИСПРАВЛЕНО: Убран Binding, добавлено x:Name -->
        <DataGrid x:Name="TrainersDataGrid"
                  Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Специализация" Binding="{Binding Specialization}" Width="*"/>
                <!-- Можно добавить телефон, если есть в модели -->
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>