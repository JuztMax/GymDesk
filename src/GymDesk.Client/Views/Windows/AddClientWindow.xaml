<Window x:Class="GymDesk.Client.Views.Windows.AddClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление клиента" 
        Height="550" Width="500"
        MinHeight="500" MinWidth="450"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="*"/>
            <!-- Контент с прокруткой -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <TextBlock Text="Новый клиент" FontSize="26" FontWeight="Bold" Margin="0,0,0,25"/>

        <!-- ScrollViewer гарантирует, что ничего не обрежется -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="Имя *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtFirstName" Padding="10" FontSize="14" Margin="0,0,0,20"/>

                <TextBlock Text="Фамилия *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtLastName" Padding="10" FontSize="14" Margin="0,0,0,20"/>

                <TextBlock Text="Телефон" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtPhone" Padding="10" FontSize="14" Margin="0,0,0,20"/>

                <TextBlock Text="Email" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtEmail" Padding="10" FontSize="14"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки всегда внизу -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button x:Name="BtnSave" 
                    Content="Сохранить" Width="120" Height="40" 
                    Background="#27ae60" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" FontSize="14" Cursor="Hand" Click="BtnSave_Click"/>

            <Button x:Name="BtnCancel" 
                    Content="Отмена" Width="120" Height="40" Margin="15,0,0,0"
                    Background="#95a5a6" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" FontSize="14" Cursor="Hand" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>