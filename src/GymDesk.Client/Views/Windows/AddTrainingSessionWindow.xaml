<Window x:Class="GymDesk.Client.Views.Windows.AddTrainingSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая тренировка" Height="580" Width="500"
        MinHeight="550" MinWidth="450"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Запись на тренировку" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <!-- Выбор клиента -->
            <TextBlock Text="Клиент *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbClients" Padding="10" FontSize="14" Margin="0,0,0,15" SelectedValuePath="Id">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding LastName}" FontWeight="SemiBold"/>
                            <Run Text=" "/>
                            <Run Text="{Binding FirstName}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Выбор тренера -->
            <TextBlock Text="Тренер *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbTrainers" Padding="10" FontSize="14" Margin="0,0,0,15" SelectedValuePath="Id">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding LastName}" FontWeight="SemiBold"/>
                            <Run Text=" "/>
                            <Run Text="{Binding FirstName}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Дата и Время -->
            <TextBlock Text="Дата *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <DatePicker x:Name="DpSessionDate" Padding="10" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock Text="Время *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtSessionTime" Padding="10" FontSize="14" Margin="0,0,0,15" 
                     ToolTip="Формат: ЧЧ:ММ (например, 18:30)"/>

            <!-- Заметки -->
            <TextBlock Text="Заметки" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtNotes" Padding="10" FontSize="14" AcceptsReturn="True" Height="80" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSave" Content="Сохранить" Width="120" Height="40" 
                    Background="#27ae60" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" FontSize="14" Cursor="Hand" Click="BtnSave_Click"/>

            <Button x:Name="BtnCancel" Content="Отмена" Width="120" Height="40" Margin="15,0,0,0"
                    Background="#95a5a6" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" FontSize="14" Cursor="Hand" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>