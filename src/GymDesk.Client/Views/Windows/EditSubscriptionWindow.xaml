<Window x:Class="GymDesk.Client.Views.Windows.EditSubscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование абонемента" 
        Height="620" Width="500"
        MinHeight="580" MinWidth="450"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Изменение абонемента" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Убран ScrollViewer для единообразия с AddSubscriptionWindow -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBlock Text="Клиент *" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <!-- Показывает "Фамилия Имя" -->
            <ComboBox x:Name="CmbClients" Padding="10" FontSize="14" Margin="0,0,0,15" 
                      SelectedValuePath="Id">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding LastName}" FontWeight="SemiBold"/>
                            <Run Text=" "/>
                            <Run Text="{Binding FirstName}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Тип абонемента *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbType" Padding="10" FontSize="14" Margin="0,0,0,15">
                <!-- 👇 ИСПРАВЛЕНО: "Разовый" вместо "Разовое посещение" -->
                <ComboBoxItem Content="Разовый"/>
                <ComboBoxItem Content="Месячный"/>
                <ComboBoxItem Content="Годовой"/>
            </ComboBox>

            <TextBlock Text="Дата начала *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <DatePicker x:Name="DpStartDate" Padding="10" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock Text="Дата окончания *" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <DatePicker x:Name="DpEndDate" Padding="10" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock Text="Цена (₽)" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtPrice" Padding="10" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSave" Content="Сохранить" Width="120" Height="40" 
                    Background="#27ae60" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" FontSize="14" Cursor="Hand" Click="BtnSave_Click"/>

            <Button x:Name="BtnCancel" Content="Отмена" Width="120" Height="40" Margin="15,0,0,0"
                    Background="#95a5a6" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" FontSize="14" Cursor="Hand" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>