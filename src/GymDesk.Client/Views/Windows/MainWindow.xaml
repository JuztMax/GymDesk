<Window x:Class="GymDesk.Client.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GymDesk - Система управления" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Левая колонка: Меню (200px) -->
            <ColumnDefinition Width="200"/>
            <!-- Правая колонка: Контент (всё остальное) -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- САЙДБАР (Меню) -->
        <Border Grid.Column="0" Background="#2c3e50" Padding="10">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="GYM DESK" Foreground="White" 
                           FontSize="20" FontWeight="Bold" 
                           Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <!-- Кнопки навигации -->
                <Button Content="👥 Клиенты" Tag="ClientsPage" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="NavButton_Click"/>

                <Button Content="👨‍🏫 Тренеры" Tag="TrainersPage" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="NavButton_Click"/>

                <Button Content="💳 Абонементы" Tag="SubscriptionsPage" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="NavButton_Click"/>

                <Button Content="📅 Тренировки" Tag="TrainingSessionsPage" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="NavButton_Click"/>
            </StackPanel>
        </Border>

        <!-- ОБЛАСТЬ КОНТЕНТА -->
        <Border Grid.Column="1" Background="#ecf0f1" Padding="20">
            <!-- Frame будет загружать сюда наши страницы (UserControl) -->
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>